# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API

# Project reference ID  (e.g. "abcdefghijklmnop")
SUPABASE_PROJECT_ID="your-supabase-project-id"

# Anon / public key — safe to expose in the browser
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Project URL  (e.g. "https://abcdefghijklmnop.supabase.co")
SUPABASE_URL="https://your-project-id.supabase.co"

# These VITE_ copies make the values available in the client bundle
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Service-role key — SERVER ONLY, never expose to the browser
# Find in: Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── AI Gateway ──────────────────────────────────────────────────────────────
# Lovable AI Gateway key (used for LLM calls via Maya the receptionist)
# Find in: lovable.dev → account settings → API keys
LOVABLE_API_KEY="your-lovable-api-key"

# ─── Vapi / AI tool webhooks (optional but recommended) ──────────────────────
# Shared secret for authenticating inbound Vapi webhook calls.
# Set any random string here and the same value in your Vapi dashboard.
# If omitted, the /api/public/ai/* endpoints run unauthenticated (dev only).
AI_SHARED_SECRET="your-random-secret-string"

# ─── Twilio SMS (optional) ───────────────────────────────────────────────────
# If all three are set, real SMS confirmations are sent after bookings.
# If any is missing, SMS is gracefully simulated (logged to console only).
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_NUMBER="+15558675309"
